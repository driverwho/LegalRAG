# Template for environment variables
# Copy this file to .env and fill in the values

# DashScope API Key (required for embedding and LLM)
DASHSCOPE_API_KEY=your_api_key_here

# Embedding model
EMBEDDING_MODEL=text-embedding-v3

# LLM configuration
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# Moonshot / Kimi (used as fallback when LLM_FALLBACK_CHAIN is not set)
MOONSHOT_API_KEY=your_moonshot_api_key_here
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=kimi-k2.5

# ---------- LLM Preprocessing Fallback Chain ----------
# Controls how document preprocessing degrades when the primary LLM (DashScope) fails.
#
# Retry behavior per provider:
LLM_FALLBACK_MAX_RETRIES=3
LLM_FALLBACK_RETRY_DELAY=2.0
#
# Option A: Simple (just set MOONSHOT_API_KEY above, leave LLM_FALLBACK_CHAIN empty)
#   → Auto-builds: DashScope → Kimi → mark pending
#
# Option B: Full control (JSON array, order = degradation priority)
#   Each entry: name, api_key_env (references another env var), base_url, model
#   api_key_env points to the ENV VAR NAME holding the key (not the key itself).
#
# LLM_FALLBACK_CHAIN=[{"name":"kimi","api_key_env":"MOONSHOT_API_KEY","base_url":"https://api.moonshot.cn/v1","model":"kimi-k2.5"}]
#
# Multi-provider example (DashScope → Kimi → DeepSeek → mark pending):
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# LLM_FALLBACK_CHAIN=[{"name":"kimi","api_key_env":"MOONSHOT_API_KEY","base_url":"https://api.moonshot.cn/v1","model":"kimi-k2.5"},{"name":"deepseek","api_key_env":"DEEPSEEK_API_KEY","base_url":"https://api.deepseek.com","model":"deepseek-chat"}]

# Vector store
COLLECTION_NAME=agent_rag
CHROMADB_PERSIST_DIR=./chroma_db

# Server
APP_HOST=0.0.0.0
APP_PORT=5000
DEBUG=True

# Document processing
CHUNK_SIZE=500
CHUNK_OVERLAP=50
SIMILARITY_THRESHOLD=0.5
MAX_RESULTS=10

# Upload
UPLOAD_FOLDER=./temp/vector_uploads
